# Copy to .env and fill in. .env is gitignored.
# Or just export these in your ~/.zshrc / ~/.bashrc — the script reads from the env.

OPENAI_IMAGE_API_KEY=sk-replace-me
OPENAI_IMAGE_BASE_URL=https://jmrai.net/v1

# Optional: override the model id if your host uses a different name
# OPENAI_IMAGE_MODEL=gpt-image-2
